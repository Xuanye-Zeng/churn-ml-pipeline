{
  "selection_metric": "f1",
  "test_size": 0.2,
  "random_state": 42,
  "cross_validation": {
    "enabled": true,
    "folds": 5
  },
  "torch": {
    "enabled": true,
    "epochs": 20,
    "batch_size": 128,
    "learning_rate": 0.001,
    "hidden_dims": [128, 64],
    "dropout": 0.1,
    "weight_decay": 0.0001,
    "validation_split": 0.2,
    "early_stopping_patience": 4,
    "min_delta": 0.0005
  },
  "models": {
    "logistic_regression": {
      "enabled": true,
      "max_iter": 2000
    },
    "random_forest": {
      "enabled": true,
      "n_estimators": 200,
      "max_depth": 8,
      "min_samples_leaf": 2
    }
  }
}
